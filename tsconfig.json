{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@vendetta": ["./vendetta.d.ts"],
      "@vendetta/*": ["./vendetta.d.ts"]
    }
  },
  "include": ["plugins/**/src/**/*.ts", "plugins/**/src/**/*.tsx"]
}
